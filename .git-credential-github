#!/bin/bash
# Git credential helper for GitHub
# Reads token from workspace .secrets/github-token
# Returns git-compatible credential format

WORKSPACE="${HOME}/.openclaw/workspace"
TOKEN_FILE="${WORKSPACE}/.secrets/github-token"

if [ -f "$TOKEN_FILE" ]; then
    TOKEN=$(cat "$TOKEN_FILE")
    echo "protocol=https"
    echo "host=github.com"
    echo "username=Aibsurd"
    echo "password=$TOKEN"
fi
